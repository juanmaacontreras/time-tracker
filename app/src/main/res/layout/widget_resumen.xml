<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w2_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/w2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RESUMEN"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:letterSpacing="0.14" />

        <TextView
            android:id="@+id/w2_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/ink"
            android:textSize="20sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/w2_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:background="@drawable/chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="Día"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/w2_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:background="@drawable/chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="Semana"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/w2_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="Mes"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n0" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t0" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p0" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="9dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p1" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="9dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p2" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="9dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p3" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="9dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p4" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w2_row5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="9dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/w2_n5" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:maxLines="1" android:ellipsize="end"
                android:text="" android:textColor="@color/ink" android:textSize="13sp" />
            <TextView android:id="@+id/w2_t5" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="@color/inkSoft" android:textSize="12sp" android:fontFamily="monospace" />
        </LinearLayout>
        <ProgressBar android:id="@+id/w2_p5" style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="3dp"
            android:max="100" android:progress="0" android:progressTint="@color/indigo"
            android:progressBackgroundTint="@color/grid" />
    </LinearLayout>

    <TextView
        android:id="@+id/w2_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/muted"
        android:textSize="10sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/w2_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Sin registros"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
