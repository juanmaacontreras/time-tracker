<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/w_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="En reposo"
        android:textColor="@color/muted"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <Chronometer
            android:id="@+id/w_chrono"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="@color/ink"
            android:textSize="26sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/w_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pausar"
            android:textColor="@color/ink"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/w_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parar"
            android:textColor="@color/live"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/w_slot0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon0" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name0" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon1" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon2" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/w_slot3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon3" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon4" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon5" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name5" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/w_row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:weightSum="3"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/w_slot6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon6" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name6" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon7" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name7" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/w_slot8"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip"
            android:padding="6dp">
            <ImageView android:id="@+id/w_icon8" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="5dp" android:src="@drawable/ic_play" />
            <TextView android:id="@+id/w_name8" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/ink" android:textSize="12sp"
                android:maxLines="1" android:ellipsize="end" android:text="—" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/w_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/muted"
        android:textSize="10sp"
        android:visibility="gone" />
</LinearLayout>
