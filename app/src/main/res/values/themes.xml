<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Bitacora" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper</item>
        <item name="colorPrimary">@color/indigo</item>
        <item name="colorAccent">@color/indigo</item>
    </style>

    <!-- Diálogos con la misma estética "papel/tinta" del resto de la app, en vez del
         gris genérico de AppCompat. Los colores referenciados ya tienen variante
         values-night, así que se adapta solo al tema oscuro. -->
    <style name="AppDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/inkSoft</item>
        <item name="colorAccent">@color/indigo</item>
    </style>
</resources>
